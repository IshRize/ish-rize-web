# Copy this file to .env.local and set values for your local development.
# API_BASE_URL is server-only (read by Next.js route handlers) — never exposed to
# the browser. The browser talks only to this app's own /api/* routes, which
# proxy to the backend and attach the JWT from an httpOnly cookie. This keeps the
# token out of client-side JS entirely.

# Base URL of the running IshRize backend REST API.
#   - Local backend: http://localhost:4000/api
API_BASE_URL=http://localhost:4000/api

# Origin of the backend's Socket.io server. Public (no secret) — the browser
# connects to this directly for live schedule updates, since WebSocket upgrades
# cannot be proxied through Next.js route handlers. Authenticated via a
# short-lived token from /api/auth/socket-token (see lib/socket.ts).
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
